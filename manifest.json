{
  "manifest_version": 3,
  "name": "Twitch Favorites Sidebar",
  "description": "Pin favorite Twitch streamers with live viewer counts, smart categories, and quick management tools.",
  "version": "0.5.4",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "sidePanel",
    "identity"
  ],
  "host_permissions": [
    "https://gql.twitch.tv/*",
    "https://www.twitch.tv/*",
    "https://twitch.tv/*",
    "https://api.github.com/*",
    "https://www.googleapis.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "oauth2": {
    "client_id": "242719267292-93m70p6erqagao3ctngd98pi02vg7rcf.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.twitch.tv/*",
        "https://twitch.tv/*"
      ],
      "js": [
        "src/contentScripts/features/favoritesStore.js",
        "src/contentScripts/features/locationWatcher.js",
        "src/contentScripts/features/chatModeration.js",
        "src/contentScripts/features/updateNotifier.js",
        "src/contentScripts/features/topNav.js",
        "src/contentScripts/features/sidebarRenderer.js",
        "src/contentScripts/features/channelFavoriteButton.js",
        "src/contentScripts/features/favoritesOverlay.js",
        "src/contentScripts/features/featureController.js",
        "src/contentScripts/main.js"
      ],
      "css": [
        "styles/sidebar.css",
        "styles/overlay.css",
        "styles/buttons.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "src/contentScripts/overlayPanel.js"
      ],
      "css": [
        "styles/panelOverlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/serviceWorker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "panel/sidepanel.html"
  },
  "web_accessible_resources": [],
  "action": {
    "default_icon": {
      "16": "assets/icon16.png",
      "24": "assets/icon16.png",
      "32": "assets/icon48.png"
    },
    "default_title": "Afficher les favoris Twitch"
  }
}
